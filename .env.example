# ITMS21+ MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# JWT Secret — must be at least 32 characters. Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
MCP_SERVER_JWT_SECRET=your-secret-key-at-least-32-characters-long

# JWT Issuer — must match what Intric expects
MCP_SERVER_JWT_ISSUER=itms21-mcp

# JWT Audience — must match what Intric expects
MCP_SERVER_JWT_AUDIENCE=intric
